{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.cjs",
    "start": "node server.js",
    "clean": "rm -rf dist data-store.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^6.0.0",
    "express": "^4.19.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.20.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "@types/express": "^4.17.21"
  }
}
